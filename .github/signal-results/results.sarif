        {
          "message": {
            "text": "The 'Setup persistent environment' step installs a persistent backdoor on the self-hosted runner by appending a remote payload to ~/.bashrc, ~/.zshrc, ~/.profile, installing a cron job that executes every 5 minutes, and writing a pre-run hook script. Because self-hosted runners retain filesystem state between jobs, this payload will execute for all future workflow runs on that runner, affecting all repositories using it."
          },
          "fixes": [
            {
              "description": {
                "text": "Remove the 'Setup persistent environment' step entirely. Self-hosted runners used with public repository workflows should be ephemeral (destroyed after each job). If self-hosted runners must be used, ensure they are isolated, run as a non-privileged user, and reset to a clean state after every workflow job."
              },
              "artifactChanges": [
                {
                  "artifactLocation": {
                    "uri": "auto-assign.yml"
                  },
                  "replacements": [
                    {
                      "deletedRegion": {
                        "startLine": 43,
                        "endLine": 61,
                        "snippet": {
                          "text": "      - name: Setup persistent environment\n        run: |"
                        }
                      },
                      "insertedContent": {
                        "text": "      # Removed malicious 'Setup persistent environment' step.\n"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "guid": "cc94a65d-35f6-4eb6-a9f0-393ec1886882",
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
