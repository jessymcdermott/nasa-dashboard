                          "text": "      - name: Post comment with validation result\n        if: failure()\n        run: |\n          # Dangerous: PR_TITLE and PR_BODY are user-controlled and injected unsanitized\n          echo \"Validation failed for PR: ${{ github.event.pull_request.title }}\"\n          echo \"PR Body: ${{ github.event.pull_request.body }}\"\n          curl -X POST \\\n            -H \"Authorization: token ${{ secrets.GITHUB_TOKEN }}\" \\\n            -H \"Accept: application/vnd.github.v3+json\" \\\n            \"https://api.github.com/repos/${{ github.repository }}/issues/${{ github.event.pull_request.number }}/comments\" \\\n            -d \"{\\\"body\\\": \\\"\u274c PR title '${{ github.event.pull_request.title }}' does not follow conventional commit format.\\\"}\""
