        {
          "message": {
            "text": "The data is untrusted because it originates from a pull request fork via 'github.event.pull_request.head.sha'. This value is user-controlled, allowing an attacker to modify the repository's package.json (e.g., adding malicious postinstall scripts) that are later executed by 'npm install --ignore-scripts=false', resulting in arbitrary remote code execution."
          },
          "fixes": [
            {
              "description": {
                "text": "Use '--ignore-scripts' (which defaults to true, disabling lifecycle hooks) instead of '--ignore-scripts=false'. This prevents execution of pre/postinstall scripts from untrusted packages. For auditing purposes, prefer 'npm audit' directly on the lockfile (--package-lock-only) without installing packages at all, which entirely avoids executing any third-party scripts."
              },
              "artifactChanges": [
                {
                  "artifactLocation": {
                    "uri": "dependency-review.yml"
                  },
                  "replacements": [
                    {
                      "deletedRegion": {
